# ============================================================
# Sklepakces integration — environment variables template
# ============================================================
# Skopiuj do config/.env.sklepakces (lub zmerguj z istniejącym .env):
#     cp config/.env.sklepakces.example config/.env.sklepakces
# Plik .env (i wszystkie *.env) jest w .gitignore — secrets NIE idą gitem.
#
# Większość ustawień Hub przechowuje w SQLite table `config` (klucz/wartosc) —
# .env jest opcjonalny i służy do bootstrap'u przy fresh install.
# ============================================================

# --- HMAC shared secret z plugin PHP ---
# MUSI być IDENTYCZNY co WP option `akces_hub_hmac_secret` w plugin'ie
# (wpisany przez admin w WC → Akces Hub → tab Hub).
#
# Generowanie nowego (na RPi5 lub local):
#     python -c "import secrets; print(secrets.token_hex(32))"
#
# Hub stores secret w config table:
#     INSERT OR REPLACE INTO config (klucz, wartosc)
#     VALUES ('sklepakces_hmac_secret', '<64-hex-chars>');
#
# Lub przez Python REPL:
#     from modules.database import set_config
#     set_config('sklepakces_hmac_secret', '<64-hex-chars>')
AKCES_SKLEPAKCES_HMAC_SECRET=replace_with_64_hex_chars_from_plugin_wp_option

# --- Redis URL (nonce cache replay protection) ---
# Default: localhost:6379/0. Na RPi5 powinien być Redis już uruchomiony:
#     sudo systemctl status redis-server
#     redis-cli ping  → PONG
#
# Jeśli brak Redis — Hub uruchamia in-memory fallback (single-process,
# bez persistance). Telegram alert raz na proces przy aktywacji fallback.
#
# Hub stores w config:
#     set_config('redis_url', 'redis://localhost:6379/0')
REDIS_URL=redis://localhost:6379/0

# --- Telegram bot (reuse istniejącego Akces Hub) ---
# Plugin'owy [SHOP] + Hub'owy [HUB] — SAME bot/chat, różny prefix.
# Hub używa istniejących config keys: telegram_bot_token + telegram_chat_id
# Te są ustawione przez admin w UI Telegram modulu Akces Hub.
#
# .env tylko dla bootstrap'u jeśli ustawiasz początkowo:
#     set_config('telegram_bot_token', '<token z BotFather>')
#     set_config('telegram_chat_id', '<numeric chat ID>')
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Sklep URL (informational, dla logów + Telegram alerts) ---
SHOP_URL=https://sklepakces.pl

# --- Log level ---
# Hub używa standardowego logging Pythona via modules/logger.py.
# Sklepakces moduły print()'ują do stdout/stderr (systemd journal).
LOG_LEVEL=INFO
