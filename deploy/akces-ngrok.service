[Unit]
Description=Akces Hub - Ngrok Tunnel
After=akces-hub.service network-online.target
Wants=network-online.target
Requires=akces-hub.service

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/clean_v32
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONIOENCODING=utf-8
ExecStartPre=/bin/sleep 5
ExecStart=/usr/bin/python3 /home/pi/clean_v32/deploy/ngrok_service.py
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
