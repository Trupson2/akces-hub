# AKCES HUB - Zmienne srodowiskowe
# Skopiuj do .env i uzupelnij wartosciami:
#   cp .env.example .env

# Google Gemini AI - klucz API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Raspberry Pi SSH (uzyj kluczy SSH zamiast hasla!)
PI_HOST=192.168.1.x
PI_USER=pi

# Flask secret key (opcjonalnie - generowany automatycznie do .secret_key)
# SECRET_KEY=your_random_secret_key_here
