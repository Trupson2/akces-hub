# AKCES HUB - Zmienne srodowiskowe
# Skopiuj do .env i uzupelnij wartosciami:
#   cp .env.example .env

# Google Gemini AI - klucz API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Raspberry Pi SSH (uzyj kluczy SSH zamiast hasla!)
PI_HOST=192.168.1.x
PI_USER=pi

# Flask secret key (opcjonalnie - generowany automatycznie do .secret_key)
# SECRET_KEY=your_random_secret_key_here

# AKCES Encryption Key (Fernet, base64). Preferowane: EnvironmentFile w systemd.
# Jesli puste, modules.key_loader spadnie na /etc/akces/env.key -> ~/.akces/env.key -> <app_dir>/.env.key
# AKCES_ENCRYPTION_KEY=

# Cloudflare Turnstile (ochrona loginu przed botami). Zostaw puste = feature disabled.
# Zarejestruj: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
